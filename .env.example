# ==============================
# Gateway Service Environment Variables
# Copy this file to .env and adjust values per environment.
# ==============================

# ------------------------------
# DEV (optional: application-dev.yml already has defaults)
# ------------------------------
DEV_UI_ORIGIN=http://localhost:5173
DEV_AUTH_SERVICE_URL=http://localhost:8083
DEV_SHIPMENT_SERVICE_URL=http://localhost:8081
DEV_TRACKING_SERVICE_URL=http://localhost:8082

# Shared JWT secret with auth-service (HS256)
JWT_SECRET=change-me-in-development-use-at-least-32-bytes

# Access token TTL used by auth-service (seconds)
JWT_TTL_SECONDS=3600

# Refresh token TTL used by auth-service (seconds)
JWT_REFRESH_TTL_SECONDS=86400

# ------------------------------
# PROD (required for prod profile)
# Replace with real production endpoints
# ------------------------------
PROD_UI_ORIGIN=https://app.paquetrack.com
PROD_AUTH_SERVICE_URL=https://auth.paquetrack.com
PROD_SHIPMENT_SERVICE_URL=https://shipment.paquetrack.com
PROD_TRACKING_SERVICE_URL=https://tracking.paquetrack.com

# ------------------------------
# AUTH SERVICE (used by the combined docker-compose example)
# ------------------------------
AUTH_DB_URL=jdbc:postgresql://auth-db:5432/auth_db
AUTH_DB_USER=auth
AUTH_DB_PASSWORD=auth
AUTH_JPA_DDL_AUTO=update
AUTH_JPA_SHOW_SQL=true
AUTH_SECURITY_HSTS_ENABLED=false
AUTH_LOGIN_RATE_LIMIT=100
